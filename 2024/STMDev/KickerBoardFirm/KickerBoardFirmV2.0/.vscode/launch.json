{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cortex Debug",
      "cwd": "${workspaceRoot}",
      "executable": "./build/KickerBoardFirmV2.0.elf",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "device": "STM32F303K8",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f3x.cfg"
      ],
      "svdFile": "./STM32F303.svd",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      },
      "openOCDLaunchCommands": [
        "-c",
        "adapter_khz 950"
      ]
    }
  ]
}