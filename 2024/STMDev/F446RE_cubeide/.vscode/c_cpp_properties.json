{
  "configurations": [
    {
      "name": "macos-clang-arm64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "USE_HAL_DRIVER",
        "STM32F446xx"
      ],
      "intelliSenseMode": "macos-clang-arm64",
      "compilerPath": "/usr/bin/clang",
      "compilerArgs": [
        "-mcpu=cortex-m4",
        "mthumb"
      ],
      "cStandard": "${default}",
      "cppStandard": "${default}"
    }
  ],
  "version": 4
}